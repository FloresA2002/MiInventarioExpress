<div class="container mt-5">
<h2>Chat en tiempo real</h2>

<div id="chat" style="border:1px solid #ccc; height:300px; overflow-y:scroll; padding:10px;">
</div>

<input id="msg" class="form-control mt-2" placeholder="Escribe un mensaje">
<button onclick="enviar()" class="btn btn-primary mt-2">Enviar</button>
</div>

<script src="/socket.io/socket.io.js"></script>

<script>
const socket = io();

const user = "{{user.username}}";

function enviar() {
  const input = document.getElementById("msg");
  const mensaje = input.value;

  socket.emit("mensaje", {
    user: user,
    msg: mensaje
  });

  input.value = "";
}

socket.on("mensaje", (data) => {
  const chat = document.getElementById("chat");

  const div = document.createElement("div");
  div.innerHTML = `<strong>${data.user}:</strong> ${data.msg}`;

  chat.appendChild(div);
});
</script>
